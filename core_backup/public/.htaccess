# Optional: if ModSecurity causes 403 on POST, try this block; if HTTP 500, remove the whole <IfModule mod_security2.c> section.
<IfModule mod_security2.c>
    SecRule REQUEST_URI "@beginsWith /admin/general-settings" "id:9001000,phase:1,pass,nolog,ctl:ruleEngine=Off"
</IfModule>

<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
